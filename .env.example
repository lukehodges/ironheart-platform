# =============================================================================
# Ironheart Refactor — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked [REQUIRED] must be set before npm run dev will work.
# Variables marked [OPTIONAL] have defaults or are only needed in production.
# Variables marked [PROD ONLY] are not needed in development.
# =============================================================================

# =============================================================================
# Database
# =============================================================================
# [REQUIRED] PostgreSQL connection string.
# Same database as the legacy ironheart project — do NOT create a separate DB.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/ironheart

# =============================================================================
# WorkOS AuthKit — [REQUIRED] Get these from WorkOS dashboard → API Keys
# =============================================================================
WORKOS_CLIENT_ID=""
WORKOS_API_KEY=""
WORKOS_REDIRECT_URI="http://localhost:3000/api/auth/callback"
WORKOS_COOKIE_PASSWORD=""   # Generate: openssl rand -base64 32
# Auth provider — 'workos' (default) or 'legacy' (emergency rollback, no redeploy needed)
AUTH_PROVIDER="workos"

# =============================================================================
# Inngest
# =============================================================================
# [OPTIONAL in development] Not needed when using the Inngest dev server locally.
# Run `npx inngest-cli@latest dev` in a separate terminal — it auto-discovers.
#
# [REQUIRED in production] Get these from https://app.inngest.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# =============================================================================
# Upstash Redis
# =============================================================================
# [REQUIRED in Phase 3+] Get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# =============================================================================
# Sentry
# =============================================================================
# [OPTIONAL] Error monitoring. Leave empty to disable Sentry.
NEXT_PUBLIC_SENTRY_DSN=

# [PROD ONLY] Used for uploading source maps during CI builds
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=ironheart-refactor
SENTRY_AUTH_TOKEN=

# =============================================================================
# Application
# =============================================================================
# [OPTIONAL] Default tenant slug for development
DEFAULT_TENANT_SLUG=default

# [OPTIONAL] Log level. Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# =============================================================================
# Platform Admin
# =============================================================================
# [BOOTSTRAP ONLY] Comma-separated list of emails to auto-promote to platform
# admin on their first login. Once a user has been promoted (isPlatformAdmin=true
# is written to the database), this env var is no longer consulted for that user.
# Remove this variable from production once all initial admins are bootstrapped.
# Source of truth for ongoing access is the users.isPlatformAdmin DB column.
PLATFORM_ADMIN_EMAILS=

# ─── Phase 4: Notifications ──────────────────────────────────────────────────
# Email provider: resend (default) or console (dev/test — no real emails)
NOTIFICATION_EMAIL_PROVIDER=console
# SMS provider: twilio (default) or console (dev/test — no real SMS)
NOTIFICATION_SMS_PROVIDER=console

# Resend (production email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Your Business Name

# Twilio (production SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# ─── Phase 4: Calendar Sync ───────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM OAuth token encryption
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_TOKEN_ENCRYPTION_KEY=

# Google Calendar OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Application base URL (used for OAuth redirects and webhook registration)
APP_URL=http://localhost:3000

# ─── AI Agent ────────────────────────────────────────────────────────────────
# [REQUIRED for AI features] Get from https://console.anthropic.com
ANTHROPIC_API_KEY=
