Table tenant_module_settings {
  id uuid [pk]
  tenantId uuid
  moduleId uuid
  settingKey text
  value jsonb [null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
}

Table tenant_modules {
  id uuid [pk]
  tenantId uuid
  moduleId uuid
  isEnabled boolean [default: false]
  isCustom boolean [default: false]
  setupPaid boolean [default: false]
  monthlyRate decimal [null]
  config jsonb [null]
  activatedAt timestamp [null]
  expiresAt timestamp [null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
}

Table tenant_portals {
  id uuid [pk]
  tenantId uuid
  templateId uuid
  urlPath text
  displayName text
  colorOverrides jsonb [null]
  labelOverrides jsonb [null]
  formOverrides jsonb [null]
  requiresLocation boolean [default: true]
  maxTravelMinutes int [null]
  travelPadding int [default: 15]
  availabilityMode AvailabilityMode [null]
  isActive boolean [default: true]
  isDefault boolean [default: false]
  sortOrder int [default: 0]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  skipReservation boolean [null]
  bookingSettings jsonb [null]
}

Table tenants {
  id uuid [pk]
  name text
  slug text
  domain text [null]
  plan PlanType
  status TenantStatus
  stripeCustomerId text [null]
  subscriptionId text [null]
  billingEmail text [null]
  maxUsers int [default: 5]
  maxStaff int [default: 10]
  maxBookingsMonth int [default: 500]
  storageUsedBytes bigint [default: 0]
  storageLimitBytes bigint
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  trialEndsAt timestamp [null]
  deletedAt timestamp [null]
}

Table travel_logs {
  id uuid [pk]
  bookingId uuid [null]
  date date
  fromPostcode text [null]
  toPostcode text [null]
  distanceMiles decimal
  durationMins int
  mileageRate decimal [null]
  mileageCost decimal [null]
  createdAt timestamp [default: `now()`]
  userId uuid
}

Table user_availability {
  id uuid [pk]
  userId uuid
  type AvailabilityType
  dayOfWeek int [null]
  specificDate date [null]
  endDate date [null]
  startTime text
  endTime text
  reason text [null]
  isAllDay boolean [default: false]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
}

Table user_capacities {
  id uuid [pk]
  tenantId uuid
  userId uuid [null]
  date date
  maxBookings int [default: 1]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
}

Table user_external_events {
  id uuid [pk]
  tenantId uuid
  userId uuid
  userIntegrationId uuid
  externalEventId text
  provider CalendarIntegrationProvider
  summary text
  description text [null]
  location text [null]
  startTime timestamp
  endTime timestamp
  isAllDay boolean [default: false]
  blocksAvailability boolean [default: true]
  attendees jsonb [null]
  metadata jsonb [null]
  lastSyncedAt timestamp [default: `now()`]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  deletedAt timestamp [null]
}

Table user_integration_sync_logs {
  id uuid [pk]
  userIntegrationId uuid
  syncType CalendarSyncType
  direction SyncDirection
  status SyncStatus
  entityType text [null]
  entityId uuid [null]
  externalId text [null]
  itemsProcessed int [default: 0]
  itemsSucceeded int [default: 0]
  itemsFailed int [default: 0]
  errorMessage text [null]
  errorDetails jsonb [null]
  metadata jsonb [null]
  startedAt timestamp [default: `now()`]
  completedAt timestamp [null]
  durationMs int [null]
  externalEventId text [null]
}

Table user_integrations {
  id uuid [pk]
  tenantId uuid
  userId uuid
  provider CalendarIntegrationProvider
  status IntegrationStatus
  encryptedAccessToken text [null]
  encryptedRefreshToken text [null]
  tokenExpiresAt timestamp [null]
  tokenVersion int [default: 1]
  providerAccountId text [null]
  calendarId text [null]
  syncEnabled boolean [default: true]
  pushBookingsToCalendar boolean [default: true]
  blockTimeOnCalendar boolean [default: true]
  importCalendarEvents boolean [default: false]
  twoWaySync boolean [default: false]
  watchChannelId text [null]
  watchChannelToken text [null]
  watchChannelExpiration timestamp [null]
  watchResourceId text [null]
  lastSyncAt timestamp [null]
  lastSyncStatus text [null]
  lastSyncError text [null]
  nextSyncAt timestamp [null]
  connectedAt timestamp [null]
  connectedBy uuid [null]
  disconnectedAt timestamp [null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
}

Table user_roles {
  userId uuid
  roleId uuid
  grantedAt timestamp [default: `now()`]
  grantedBy uuid [null]
  expiresAt timestamp [null]
  indexes { (userId, roleId) [pk] }
}

Table users {
  id uuid [pk]
  tenantId uuid
  email text
  emailVerified timestamp [null]
  passwordHash text [null]
  firstName text
  lastName text
  displayName text [null]
  avatarUrl text [null]
  phone text [null]
  phoneVerified timestamp [null]
  timezone text
  locale text
  type UserType
  status UserStatus
  lastLoginAt timestamp [null]
  lastActiveAt timestamp [null]
  loginCount int [default: 0]
  failedLoginAttempts int [default: 0]
  lockedUntil timestamp [null]
  twoFactorEnabled boolean [default: false]
  twoFactorSecret text [null]
  recoveryCodesHash text [null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  deletedAt timestamp [null]
  invitedById uuid [null]
  bio text [null]
  dayRate decimal [null]
  employeeType EmployeeType [null]
  hourlyRate decimal [null]
  isTeamMember boolean [default: false]
  jobTitle text [null]
  maxConcurrentBookings int [default: 1, null]
  maxDailyBookings int [null]
  mileageRate decimal [null]
  serviceIds uuid[] [null]
  staffStatus StaffStatus [null]
  startDate timestamp [null]
  isPlatformAdmin boolean [default: false]
  bankAccountName text [null]
  bankSortCode text [null]
  bankAccountNumber text [null]
  workos_user_id text [null]
}

Table venues {
  id uuid [pk]
  tenantId uuid
  name text
  addressLine1 text [null]
  addressLine2 text [null]
  city text [null]
  county text [null]
  postcode text [null]
  country text
  latitude decimal [null]
  longitude decimal [null]
  phone text [null]
  email text [null]
  isDefault boolean [default: false]
  active boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  additionalCost decimal [null]
}

Table workflow_actions {
  id uuid [pk]
  workflowId uuid
  actionType WorkflowActionType
  config jsonb
  order int [default: 0]
  enabled boolean [default: true]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
}

Table workflow_executions {
  id uuid [pk]
  workflowId uuid
  tenantId uuid
  triggerEvent text
  triggerData jsonb
  status WorkflowExecutionStatus
  startedAt timestamp [default: `now()`]
  completedAt timestamp [null]
  errorMessage text [null]
  actionsExecuted int [default: 0]
  actionResults jsonb [null]
}

Table workflows {
  id uuid [pk]
  tenantId uuid
  name text
  description text [null]
  enabled boolean [default: true]
  triggerEvent text
  conditions jsonb [null]
  delay int [null]
  createdAt timestamp [default: `now()`]
  updatedAt timestamp
  edges jsonb [null]
  isVisual boolean [default: false]
  nodes jsonb [null]
  viewport jsonb [null]
}

